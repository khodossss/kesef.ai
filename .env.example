# Copy this file to .env and fill in YOUR credentials.
# .env is git-ignored — it stays only on your machine.

# ===== Isracard (credit card) =====
# Library logs in automatically with these; you only pass the Cloudflare check.
ISRACARD_ID=your_teudat_zehut
ISRACARD_CARD6DIGITS=last_6_digits_of_card
ISRACARD_PASSWORD=your_isracard_password

# ===== Bank Hapoalim =====
# Auto-filled into the login form; you only type the SMS OTP in the window.
HAPOALIM_USERCODE=your_user_code
HAPOALIM_PASSWORD=your_password

# ===== Scraping config =====
# How many months of history to fetch (default 12).
SCRAPE_MONTHS_BACK=12
