# Copy this file to .env and fill in YOUR credentials.
# .env is git-ignored — it stays only on your machine.

# ===== Isracard (credit card) =====
# Library logs in automatically with these; you only pass the Cloudflare check.
ISRACARD_ID=your_teudat_zehut
ISRACARD_CARD6DIGITS=last_6_digits_of_card
ISRACARD_PASSWORD=your_isracard_password

# ===== Bank Hapoalim =====
# Auto-filled into the login form; you only type the SMS OTP in the window.
HAPOALIM_USERCODE=your_user_code
HAPOALIM_PASSWORD=your_password

# ===== Bank Leumi =====
# Library logs in automatically (username + password, no OTP); no typing needed.
LEUMI_USERNAME=your_username
LEUMI_PASSWORD=your_password

# ===== Scraping config =====
# How many months of history to fetch (default 12).
SCRAPE_MONTHS_BACK=12

# --- Семейный режим (опционально; см. FAMILY.md) ---
# HOUSEHOLD_STORAGE=relay        # relay | local
# HOUSEHOLD_TOKEN=kesef1.xxx.yyy # relay: выдаётся family_create/приходит от семьи (это КРЕД)
# HOUSEHOLD_DIR=                 # local: путь к общей синхронизируемой папке
# RELAY_URL=                     # relay: URL твоего Cloudflare Worker (см. relay/README.md)
# MEMBER_ID=                     # ставится автоматически при family_create/join
# MEMBER_INFO=                   # опциональная метка ("Дима, муж"); пусто → "Юзер N"
